@model List<Event>
@{
    ViewData["Title"] = "Organizatör Etkinlikleri";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="h3 mb-1">Organizatör Etkinlikleri</h1><p class="text-muted mb-0">Oluşturduğunuz etkinlikleri yönetin.</p></div>
    <a class="btn btn-primary" href="/Organizer/Events/Create">Yeni Etkinlik</a>
</div>

<div class="table-responsive">
    <table class="table align-middle">
        <thead><tr><th>Etkinlik</th><th>Kategori</th><th>Tarih</th><th>Kontenjan</th><th>Durum</th><th></th></tr></thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Category?.Name</td>
                <td>@item.Date.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@item.Participants.Count / @item.Capacity</td>
                <td><span class="badge @(item.IsActive ? "text-bg-success" : "text-bg-secondary")">@(item.IsActive ? "Aktif" : "Pasif")</span></td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-info" href="/Organizer/Events/Participants/@item.Id">Katılımcılar</a>
                    <a class="btn btn-sm btn-outline-primary" href="/Organizer/Events/Edit/@item.Id">Düzenle</a>
                    <a class="btn btn-sm btn-outline-danger" href="/Organizer/Events/Delete/@item.Id">Sil</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
