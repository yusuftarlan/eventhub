@model List<EventCardViewModel>
@{
    ViewData["Title"] = "Ana Sayfa";
}

<section class="hero-section mb-5">
    <div class="hero-content">
        <span class="badge text-bg-light mb-3">Etkinlik & Workshop Yönetimi</span>
        <h1>EventHub</h1>
        <p>Yaklaşan workshopları keşfedin, etkinliklere katılın ve organizasyon süreçlerini tek panelden yönetin.</p>
        <a class="btn btn-primary btn-lg" asp-controller="Events" asp-action="Index">Etkinlikleri Keşfet</a>
    </div>
</section>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h4 mb-0">Yaklaşan Etkinlikler</h2>
    <a asp-controller="Events" asp-action="Index" class="btn btn-outline-primary btn-sm">Tümünü Gör</a>
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-md-6 col-xl-4">
            <partial name="_EventCard" model="item" />
        </div>
    }
</div>
