@model EventListViewModel
@{
    ViewData["Title"] = "Etkinlikler";
}

<div class="page-heading">
    <h1>Etkinlikler</h1>
    <p>Workshop ve etkinlikleri filtreleyerek size uygun programı bulun.</p>
</div>

<form method="get" class="row g-2 align-items-end mb-4">
    <div class="col-md-5">
        <label class="form-label">Arama</label>
        <input class="form-control" name="searchTerm" value="@Model.SearchTerm" placeholder="Başlık, açıklama veya konum">
    </div>
    <div class="col-md-4">
        <label class="form-label">Kategori</label>
        <select class="form-select" name="categoryId" asp-items="Model.Categories">
            <option value="">Tüm kategoriler</option>
        </select>
    </div>
    <div class="col-md-3 d-grid">
        <button class="btn btn-primary" type="submit">Filtrele</button>
    </div>
</form>

<div class="row g-4">
    @foreach (var item in Model.Events)
    {
        <div class="col-md-6 col-xl-4">
            <partial name="_EventCard" model="item" />
        </div>
    }
</div>

@if (!Model.Events.Any())
{
    <div class="alert alert-info">Aradığınız kriterlere uygun etkinlik bulunamadı.</div>
}
