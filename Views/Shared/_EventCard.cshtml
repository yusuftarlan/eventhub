@model EventCardViewModel

<div class="card event-card h-100 shadow-sm">
    <img src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "https://images.unsplash.com/photo-1515169067865-5387ec356754?auto=format&fit=crop&w=1200&q=80" : Model.ImageUrl)" class="card-img-top" alt="@Model.Title">
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between gap-2 align-items-start mb-2">
            <span class="badge text-bg-primary">@Model.CategoryName</span>
            <span class="small text-muted">@Model.Date.ToString("dd MMM yyyy HH:mm")</span>
        </div>
        <h5 class="card-title">@Model.Title</h5>
        <p class="card-text text-muted flex-grow-1">@((Model.Description.Length > 120) ? Model.Description[..120] + "..." : Model.Description)</p>
        <div class="small text-muted mb-3">
            <div>@Model.Location</div>
            <div>@Model.ParticipantCount / @Model.Capacity katılımcı, @Model.RemainingCapacity boş kontenjan</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-outline-primary btn-sm" asp-controller="Events" asp-action="Details" asp-route-id="@Model.Id">Detay</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-controller="Events" asp-action="Favorite" asp-route-id="@Model.Id" method="post">
                    <button class="btn btn-sm @(Model.IsFavorite ? "btn-warning" : "btn-outline-warning")" type="submit">
                        @(Model.IsFavorite ? "Favoriden Çıkar" : "Favori")
                    </button>
                </form>
            }
        </div>
    </div>
</div>
